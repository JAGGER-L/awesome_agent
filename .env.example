# Copy this file to .env for local development. Never commit real secrets.

# Default model provider: DeepSeek (OpenAI-compatible Chat Completions API).
AWESOME_AGENT_DEEPSEEK_API_KEY=
AWESOME_AGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com
AWESOME_AGENT_DEEPSEEK_PRO_MODEL=deepseek-v4-pro
AWESOME_AGENT_DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
AWESOME_AGENT_DEEPSEEK_THINKING_ENABLED=true
AWESOME_AGENT_DEEPSEEK_REASONING_EFFORT=high

# Agent model defaults. Role-specific overrides are a JSON object.
AWESOME_AGENT_LEADER_MODEL=deepseek-v4-pro
AWESOME_AGENT_TEAMMATE_MODEL=deepseek-v4-flash
AWESOME_AGENT_VERIFIER_MODEL=deepseek-v4-flash
AWESOME_AGENT_SUBAGENT_MODEL=deepseek-v4-flash
AWESOME_AGENT_ROLE_MODEL_OVERRIDES={}

# Optional future OpenAI provider.
OPENAI_API_KEY=
OPENAI_MODEL=

AWESOME_AGENT_DATABASE_URL=postgresql+asyncpg://awesome_agent:awesome_agent@localhost:54329/awesome_agent
AWESOME_AGENT_CHECKPOINT_DATABASE_URL=postgresql://awesome_agent:awesome_agent@localhost:54329/awesome_agent

# Optional local path overrides. Defaults live under ~/.awesome-agent/.
# AWESOME_AGENT_LOCAL_CONFIG_PATH=C:/Users/example/.awesome-agent/config.toml
# AWESOME_AGENT_WORKSPACE_ROOT=C:/Users/example/.awesome-agent/worktrees
AWESOME_AGENT_LEASE_DURATION_SECONDS=60
AWESOME_AGENT_HEARTBEAT_INTERVAL_SECONDS=15
AWESOME_AGENT_MAX_CLAIM_ATTEMPTS=3

# Both memory layers remain disabled in committed defaults.
AWESOME_AGENT_MEM0_API_KEY=
AWESOME_AGENT_BUILTIN_MEMORY_ENABLED=false
AWESOME_AGENT_MEM0_ENABLED=false

AWESOME_AGENT_LOG_LEVEL=INFO
AWESOME_AGENT_ARTIFACT_ROOT=
AWESOME_AGENT_MAX_TEAMMATES=6
AWESOME_AGENT_MAX_SUBAGENTS_PER_TEAMMATE=3
AWESOME_AGENT_MAX_MODEL_CONCURRENCY=8
AWESOME_AGENT_MAX_TOOL_CONCURRENCY=12
AWESOME_AGENT_MAX_SANDBOX_CONCURRENCY=6
