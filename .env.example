# Copy this file to .env for local development. Never commit real secrets.

OPENAI_API_KEY=
OPENAI_MODEL=

AWESOME_AGENT_DATABASE_URL=postgresql+asyncpg://awesome_agent:awesome_agent@localhost:54329/awesome_agent
AWESOME_AGENT_CHECKPOINT_DATABASE_URL=postgresql://awesome_agent:awesome_agent@localhost:54329/awesome_agent

# Optional Mem0 Platform integration. Memory is disabled by default.
MEM0_API_KEY=
AWESOME_AGENT_BUILTIN_MEMORY_ENABLED=false
AWESOME_AGENT_MEM0_ENABLED=false

AWESOME_AGENT_LOG_LEVEL=INFO
AWESOME_AGENT_ARTIFACT_ROOT=
AWESOME_AGENT_MAX_TEAMMATES=6
AWESOME_AGENT_MAX_SUBAGENTS_PER_TEAMMATE=3
AWESOME_AGENT_MAX_MODEL_CONCURRENCY=8
AWESOME_AGENT_MAX_TOOL_CONCURRENCY=12
AWESOME_AGENT_MAX_SANDBOX_CONCURRENCY=6
